{
    "type": "table",
    "namespace": "app",

    "fields": [
        { "type": "BIGINT",  "name": "id", "explicit_type": "uint32_t" },
        { "type": "VARCHAR", "name": "name" },
        { "type": "INT",     "name": "age" }
    ],

    "keys": { "primary": ["id"] },

    "remarks": [
        { "type": "IDENTITY", "field": "id" },
        { "type": "UNIQUE",   "field": "name" }
    ],

    "layouts": [
        {
            "type": "select",
            "name": "select_adults",
            "params": [ { "name": "min_age", "type": "INT" } ],
            "condition": "age >= $1",
            "order_by": "age DESC, name"
        }
    ]
}
