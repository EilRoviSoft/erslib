body {
    font-family: "Lato";
    font-size: 18px;
    color: #eeeeee;
    background-color: rgba(255, 0, 0, 0.25);
}

#panel {
    position: absolute;
    left: 40px;
    top: 40px;
    width: 520px;
    padding: 20px;
    background-color: #202838dd;
    border: 2px #ffffff55;
}

h1 {
    font-size: 28px;
    color: #ffd27f;
}

p {
    margin-top: 10px;
    margin-bottom: 10px;
}

button {
    margin-top: 15px;
    padding: 8px 14px;
    background-color: #405070;
    color: white;
}

button:hover {
    background-color: #6078a0;
}
