{
	"version": 4,
	"configurePresets": [
		{
			"name": "linux-local-clang",
			"displayName": "linux-x64-dbg-clang",
			"inherits": "linux-clang",
			"environment": {
				"VCPKG_ROOT": "$penv{HOME}/vcpkg"
			},
			"cacheVariables": {
				"ERS_TRACE_VERBOSITY": "2",
				"ERS_TRACE_MAX_DEPTH": "3",
				"ERSLIB_BUILD_TESTS": "ON"
			}
		},
		{
			"name": "linux-local-gcc-16",
			"displayName": "linux-x64-dbg-gcc16",
			"inherits": "linux-gcc-16",
			"environment": {
				"VCPKG_ROOT": "$penv{HOME}/vcpkg"
			},
			"cacheVariables": {
				"ERS_TRACE_VERBOSITY": "2",
				"ERS_TRACE_MAX_DEPTH": "3",
				"ERSLIB_BUILD_TESTS": "ON"
			}
		}
	]
}
