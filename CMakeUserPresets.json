{
	"version": 4,
	"configurePresets": [
		{
			"name": "windows-local-clang",
			"inherits": "windows-clang",
			"hidden": true,
			"environment": {
				"VCPKG_ROOT": "D:/Libs/vcpkg"
			},
			"cacheVariables": {
				"ERS_TRACE_VERBOSITY": "2",
				"ERS_TRACE_MAX_DEPTH": "3"
			}
		},
		{
			"name": "windows-local-clang-debug",
			"displayName": "Windows Clang Debug",
			"inherits": "windows-local-clang",
			"cacheVariables": {
				"ERSLIB_BUILD_TESTS": "ON",
				"SOL_EXCEPTIONS": "ON"
			}
		},
		{
			"name": "windows-local-clang-release",
			"displayName": "Windows Clang Release w/ Debug Info",
			"inherits": "windows-local-clang",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"ERSLIB_BUILD_TESTS": "ON",
				"SOL_EXCEPTIONS": "ON"
			}
		}
	]
}
