{
	"version": 4,
	"configurePresets": [
		{
			"name": "windows-local-clang",
			"displayName": "windows-x64-dbg",
			"inherits": "windows-clang",
			"environment": {
				"VCPKG_ROOT": "D:/Libs/vcpkg"
			},
			"cacheVariables": {
				"ERS_TRACE_VERBOSITY": "2",
				"ERS_TRACE_MAX_DEPTH": "3"
			}
		},

		{
			"name": "linux-local-clang",
			"displayName": "linux-x64-dbg",
			"inherits": "linux-clang",
			"environment": {
				"VCPKG_ROOT": "$penv{HOME}/vcpkg"
			},
			"cacheVariables": {
				"ERS_TRACE_VERBOSITY": "2",
				"ERS_TRACE_MAX_DEPTH": "3"
			},
			"vendor": {
				"microsoft.com/VisualStudioSettings/CMake/1.0": {
					"intelliSenseMode": "linux-gcc-x64"
				}
			}
		}
	]
}
