{% if layout.is_bulk() %}
        static ers::Result<Generator> operator()(pqxx::dbtransaction& tnx{% for field in layout['put'] %}, {{ table.fields_by_name[field].arg_type() }} {{ field }}{% endfor %});
{% else %}
        static ers::Status operator()(pqxx::dbtransaction& tnx, {{ fn.to_camel_case(name) }}& entity);
{% endif %}

    private:
{% if layout.is_bulk() %}
        static ers::Result<pqxx::result> _dbio(pqxx::dbtransaction& tnx{% for field in layout['put'] %}, {{ table.fields_by_name[field].arg_type() }} {{ field }}{% endfor %});
{% else %}
        static ers::Result<pqxx::result> _dbio(pqxx::dbtransaction& tnx, {{ fn.to_camel_case(name) }}& entity);
{% endif %}
    };
