#pragma once

{% for name, type in include_groups %}
{% if fn.len(includes[name]) != 0 %}
// {{ name }}
{% for filename in includes[name] %}
{% if type == 'library' %}
#include <{{ filename }}>
{% elif type == 'project' %}
#include "{{ filename }}"
{% endif %}
{% endfor %}
{{ "\n" if not loop.last else "" }}{% endif %}
{% endfor %}


// Enums

namespace {{ namespace }} {
    enum class {{ fn.to_camel_case(name) }}Field : uint8_t {
{% for field in table.fields %}
        {{ fn.to_camel_case(field.name) }} = {{ loop.index0 }},
{% endfor %}
        Max = {{ fn.len(table.fields) }}
    };

    enum class {{ fn.to_camel_case(name) }}Layout : uint8_t {
{% for layout in table.layouts %}
        {{ fn.to_camel_case(layout.name) }} = {{ loop.index0 }}{{ "," if not loop.last else "" }}
{% endfor %}
    };
}


// Helpers

namespace {{ namespace }} {
    class {{ fn.to_camel_case(name) }}Config {
    public:
        static constexpr auto length = static_cast<size_t>({{ fn.to_camel_case(name) }}Field::Max);

        constexpr {{ fn.to_camel_case(name) }}Config(const std::initializer_list<{{ fn.to_camel_case(name) }}Field>& il) noexcept {
            for (const {{ fn.to_camel_case(name) }}Field it : il)
                this->_bitset.set(static_cast<size_t>(it));
        }

        constexpr bool operator[]({{ fn.to_camel_case(name) }}Field member) const noexcept {
            return this->_bitset[static_cast<size_t>(member)];
        }

    private:
        std::bitset<length> _bitset;
    };
}

namespace  {{ namespace }}::{{ name }} {
    template<dbio::PersistencyFlag>
    constexpr {{ fn.to_camel_case(name) }}Config make_config({{ fn.to_camel_case(name) }}Layout layout) = delete("non-specialized definition");

    template<>
    constexpr {{ fn.to_camel_case(name) }}Config make_config<dbio::In>({{ fn.to_camel_case(name) }}Layout layout) {
        using enum {{ fn.to_camel_case(name) }}Field;

        switch (layout) {
{% for layout in table.layouts %}
{% if fn.len(layout.get) != 0 %}
            case {{ fn.to_camel_case(name) }}Layout::{{ fn.to_camel_case(layout.name) }}:
                return { {{ layout.get | map('to_camel_case') | join(", ") }} };

{% endif %}
{% endfor %}
            default:
                return {};
        }
    }

    template<>
    constexpr {{ fn.to_camel_case(name) }}Config make_config<dbio::Out>({{ fn.to_camel_case(name) }}Layout layout) {
        using enum {{ fn.to_camel_case(name) }}Field;

        switch (layout) {
{% for layout in table.layouts %}
{% if fn.len(layout.put) != 0 %}
            case {{ fn.to_camel_case(name) }}Layout::{{ fn.to_camel_case(layout.name) }}:
                return { {{ layout.put | map('to_camel_case') | join(", ") }} };

{% endif %}
{% endfor %}
            default:
                return {};
        }
    }
}

// {{ fn.to_camel_case(name) }}

namespace {{ namespace }} {
    struct {{ fn.to_camel_case(name) }}Values {
{% for field in table.fields if field.name %}
        {{ field.class_type() }} {{ field.name }}{% if field.default %} = {{ field.default }}{% endif %};
{% endfor %}
    };

    class ERSLIB_EXPORT {{ fn.to_camel_case(name) }} : public {{ fn.to_camel_case(name) }}Values {
    public:
        using enum {{ fn.to_camel_case(name) }}Field;
        using enum {{ fn.to_camel_case(name) }}Layout;

        {{ fn.to_camel_case(name) }}() = default;
        {{ fn.to_camel_case(name) }}({{ fn.to_camel_case(name) }}Values values);
        explicit {{ fn.to_camel_case(name) }}(const pqxx::row& row, const {{ fn.to_camel_case(name) }}Config& config = {{ name }}::make_config<dbio::In>(All));

        bool init(const pqxx::row& row, const {{ fn.to_camel_case(name) }}Config& config = {{ name }}::make_config<dbio::In>(All));
    };
}

template<>
struct dbio::entity_traits<{{ namespace }}::{{ fn.to_camel_case(name) }}> {
    using field_type = {{ namespace }}::{{ fn.to_camel_case(name) }}Field;
    using layout_type = {{ namespace }}::{{ fn.to_camel_case(name) }}Layout;
    using config_type = {{ namespace }}::{{ fn.to_camel_case(name) }}Config;

    template<PersistencyFlag T>
    static constexpr config_type make_config(layout_type layout) {
        return {{ namespace }}::{{ name }}::make_config<T>(layout);
    }
};


// Database interactions

